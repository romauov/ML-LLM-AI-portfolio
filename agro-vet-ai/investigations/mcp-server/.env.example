# PostgreSQL Database Configuration
DB_HOST=10.0.3.123
DB_PORT=5432
DB_NAME=vetbot
DB_USER=vetbot
DB_PASSWORD=vetbot

# OpenAI API Configuration (VseGPT)
OPENAI_API_KEY=sk-or-vv-your-api-key-here
OPENAI_API_BASE=https://api.vsegpt.ru/v1

# Embeddings Configuration
# ВАЖНО: Модель (text-embedding-3-small) фиксирована в коде и не настраивается
# Она должна соответствовать эмбеддингам в базе данных

# Vector Search Configuration
# SIMILARITY_THRESHOLD - максимальное расстояние (distance), меньше = лучше
# Рекомендуемые значения для text-embedding-3-small: 0.4-0.5 для строгого поиска, 0.5-0.7 для более широкого
SIMILARITY_THRESHOLD=0.6
# Примечание: DEFAULT_LIMIT (количество результатов по умолчанию = 5) фиксировано в коде

# Logging
LOG_LEVEL=INFO
