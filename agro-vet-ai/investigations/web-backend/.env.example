# Конфигурация LLM (OpenRouter, локальный прокси, или любой OpenAI-совместимый API)
LLM_API_BASE=https://openrouter.ai/api/v1
LLM_API_KEY=sk-or-v1-your-api-key-here
LLM_MODEL=qwen/qwen3-coder-plus

# Логирование Helicone (опционально)
# Включите для логирования всех запросов к LLM в Helicone для мониторинга и аналитики
# Получите API ключ на https://helicone.ai
HELICONE_API_KEY=sk-helicone-your-api-key-here
HELICONE_ENABLED=false

# MCP сервер (vetretro)
VETRETRO_MCP_URL=http://localhost:8765

# Приложение
INVESTIGATIONS_PATH=../agent-workspace/investigations
AGENT_WORKSPACE_PATH=../agent-workspace

# Сервер
HOST=0.0.0.0
PORT=8000
DEBUG=true

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:8080"]
