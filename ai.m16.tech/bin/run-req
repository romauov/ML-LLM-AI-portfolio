#! /bin/bash
# Запуск сервисов с установкой пакетов

# Получить из файла .env версию образа
export $(grep -v '^#' .env | xargs)

docker pull registry.m16.tech/ml-lib:3
docker-compose -f docker/docker-compose-req.yml build app
docker-compose -f docker/docker-compose-req.yml build gradio
docker-compose -f docker/docker-compose-req.yml up
